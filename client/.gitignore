# Package-local ignores (root .gitignore covers monorepo-wide rules).
# Client-specific: Vite outputs and package-local env samples.

# Dependencies & build
node_modules
dist
dist-ssr

# Env (never commit real keys)
.env
.env.*
!.env.example

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.local

# API base URL including /api path (no trailing slash after host except path)
# Dev default if unset: http://localhost:8000/api
# Prod default if unset: /api (same-origin proxy)
# VITE_API_URL=http://localhost:8000/api

# Comms contact form (Web3Forms) — free access key from https://web3forms.com
# Your personal inbox is configured on their dashboard; it never appears in the SPA.
# VITE_WEB3FORMS_ACCESS_KEY=

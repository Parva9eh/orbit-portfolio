# Copy to .env and fill in real values. Never commit .env.
# Get a free key: https://api.nasa.gov/

NASA_API_KEY=DEMO_KEY
PORT=8000
HOST=0.0.0.0

# Comma-separated browser origins allowed to call the API.
# Leave unset for local open CORS. Set before any public deploy.
# Example: CORS_ORIGIN=http://localhost:5173,https://your-domain.example
# CORS_ORIGIN=http://localhost:5173

# API rate limit for /api/* (health is unlimited)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=120

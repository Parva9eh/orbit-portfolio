# =============================================================================
# Root .gitignore — orbit-portfolio
# Prefer root rules; package-level .gitignore files only add package-local needs.
# =============================================================================

# --- Dependencies ---
node_modules/
**/node_modules/

# --- Environment / secrets (never commit) ---
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# --- Private workspace (reviews, plans, HTML mockups) ---
docs/
**/docs/

# --- Build outputs ---
dist/
dist-ssr/
build/
**/dist/
coverage/
*.tsbuildinfo

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- OS / editor ---
.DS_Store
**/.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Vite / tooling / caches ---
*.local
.cache/
.turbo/
.vercel/
.netlify/
